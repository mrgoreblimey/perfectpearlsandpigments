# ── WordPress / WooCommerce (headless data) ─────────────────────────────
# WPGraphQL endpoint (products/nav). Leave unset to run on seed data.
# Staging (current test target):
# WORDPRESS_GRAPHQL_URL=https://staging.perfectpearlsandpigments.co.uk/graphql
# Production (once live):
# WORDPRESS_GRAPHQL_URL=https://perfectpearlsandpigments.co.uk/graphql

# ── Stripe (checkout payments) ──────────────────────────────────────────
# Use TEST keys first (pk_test_… / sk_test_…). The publishable key is exposed
# to the browser (NEXT_PUBLIC_); the secret key is server-only.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_SECRET_KEY=sk_test_xxx

# ── WooCommerce REST (order creation after payment) ─────────────────────
# Create keys in WooCommerce → Settings → Advanced → REST API (Read/Write).
# Leave unset to simulate orders (flow still completes for testing).
# WOOCOMMERCE_STORE_URL=https://staging.perfectpearlsandpigments.co.uk
# WOOCOMMERCE_CONSUMER_KEY=ck_xxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxx

# ── Customer accounts (login / my account / orders) ─────────────────────
# AUTH_MODE selects the auth backend:
#   mock → dev provider with sample data + demo login (any email / "demo1234")
#   wp   → real WPGraphQL auth; requires the free wp-graphql-jwt-authentication
#          plugin on WordPress and a GRAPHQL_JWT_AUTH_SECRET_KEY in wp-config.php.
# Defaults to mock in development, wp in production.
# AUTH_MODE=wp
# AUTH_SESSION_SECRET: ≥32 random chars, used to encrypt the session cookie.
# Generate with:  openssl rand -base64 32
AUTH_SESSION_SECRET=change-me-to-a-long-random-string
